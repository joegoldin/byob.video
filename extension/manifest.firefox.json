{
  "manifest_version": 2,
  "name": "byob - Bring Your Own Binge",
  "version": "0.1.0",
  "description": "Syncs video playback with byob.video rooms",
  "permissions": ["storage", "<all_urls>"],
  "background": {
    "scripts": ["lib/phoenix.mjs", "background.js"],
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "byob@byob.video",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {}
}
