{
  "manifest_version": 3,
  "name": "byob - Bring Your Own Binge",
  "version": "6.5.20",
  "description": "Syncs video playback with byob.video rooms",
  "permissions": ["storage", "tabs"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.crunchyroll.com/*",
        "https://crunchyroll.com/*"
      ],
      "js": ["sites/crunchyroll-bitmovin-page.js"],
      "run_at": "document_start",
      "all_frames": true,
      "world": "MAIN"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
