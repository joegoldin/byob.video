{
  "manifest_version": 3,
  "name": "byob - Bring Your Own Binge",
  "version": "0.1.0",
  "description": "Syncs video playback with byob.video rooms",
  "permissions": ["storage"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {}
}
